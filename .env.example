# RISE_Meeting uses HKUST Azure GenAI exclusively.
HKUST_GENAI_API_KEY=
HKUST_GENAI_ENDPOINT=https://hkust.azure-api.net/hkust-genai/v1/chat/completions
HKUST_GENAI_MODEL=gemini-3-flash-preview
HKUST_GENAI_TIMEOUT=60

# Bounded same-meeting expansion.
UAC_RELATED_DOC_CAP=20

# Inquiry application. Keep RISE_RAW_PDF_DIR empty in version control.
RISE_CORPUS_DIR=runs/uac_corpus/files
RISE_BM25_DIR=runs/uac_bm25
RISE_DOCUMENT_MANIFEST=runs/uac_corpus/document_manifest.json
RISE_MEETING_MANIFEST=runs/uac_corpus/meeting_manifest.json
RISE_FILENAME_MAP=runs/uac_corpus/filename_docid_map.json
RISE_RAW_PDF_DIR=
RISE_INQUIRY_DB=result/inquiry_app.sqlite
RISE_INQUIRY_BATCH_SIZE=10
RISE_INQUIRY_MEMORY_WINDOW=10
