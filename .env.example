# RISE reproduction — API credentials. Copy to `.env` and fill in.
# Each agent model routes to its provider by model-name prefix (see src/rise/decompose.py).

# --- OpenAI (gpt-5.4-mini / gpt-5.4-nano / gpt-5.4 agents; gpt-5.1 judge; TOC generation) ---
OPENAI_DIRECT_API_KEY=sk-...

# --- Xiaomi MiMo (mimo-v2.5-pro agent), OpenAI-compatible ---
XIAOMI_API_KEY=
XIAOMI_BASE_URL=https://api.xiaomimimo.com/v1

# --- optional knobs ---
# REASONING_EFFORT=high        # gpt-5.4-nano runs set this to high
# SECTION_MODEL=gpt-5.4-nano   # model used for offline TOC generation
